<!DOCTYPE html>
<html lang="<%= page.site_locale || 'en' %>">
<head>
    <meta charset="UTF-8">
    <title><%= page.title || 'Redirecting...' %></title>
    <meta http-equiv="refresh" content="0; url=<%- url_for(page.redirect_to) %>">
    <style>
        body { margin: 2rem; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
        a { color: #333; text-decoration: underline; }
    </style>
</head>
<body>
    <p>Redirecting to <a href="<%- url_for(page.redirect_to) %>"><%- url_for(page.redirect_to) %></a>...</p>
</body>
</html>
