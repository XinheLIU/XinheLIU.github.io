<%
    var isChinese = (page.site_locale || '').indexOf('zh') === 0;
    var allPosts = [];
    site.posts.each(function(post) {
        if (post.hide !== true) {
            var postIsChinese = (post.site_locale || 'zh-CN').indexOf('zh') === 0;
            if (postIsChinese === isChinese) {
                allPosts.push(post);
            }
        }
    });
    allPosts.sort(function(a, b) {
        return new Date(b.date) - new Date(a.date);
    });

    var books = site.data && site.data.books ? site.data.books : [];

    var clusterButtons = isChinese
        ? [
            { key: 'all', label: '全部' },
            { key: 'ads-systems', label: '广告系统' },
            { key: 'recommendation', label: '推荐系统' },
            { key: 'experimentation', label: '实验' },
            { key: 'causal-measurement', label: '因果' },
            { key: 'enterprise-ai', label: '企业 AI' },
            { key: 'agentic-engineering', label: '智能体工程' }
        ]
        : [
            { key: 'all', label: 'All' },
            { key: 'ads-systems', label: 'Ads systems' },
            { key: 'recommendation', label: 'Recommendation' },
            { key: 'experimentation', label: 'Experimentation' },
            { key: 'causal-measurement', label: 'Causal' },
            { key: 'enterprise-ai', label: 'Enterprise AI' },
            { key: 'agentic-engineering', label: 'Agentic engineering' }
        ];

    var clusterLabels = isChinese
        ? {
            'ads-systems': '广告系统',
            'recommendation': '推荐系统',
            'experimentation': '实验',
            'causal-measurement': '因果测量',
            'enterprise-ai': '企业 AI',
            'agentic-engineering': '智能体工程'
        }
        : {
            'ads-systems': 'Ads systems',
            'recommendation': 'Recommendation',
            'experimentation': 'Experimentation',
            'causal-measurement': 'Causal measurement',
            'enterprise-ai': 'Enterprise AI',
            'agentic-engineering': 'Agentic engineering'
        };

    function bookTitle(book) {
        return isChinese ? (book.title_zh || book.title_en) : (book.title_en || book.title_zh);
    }

    function bookSummary(book) {
        return isChinese ? (book.summary_zh || book.summary_en) : (book.summary_en || book.summary_zh);
    }

    function bookStatus(book) {
        return isChinese ? (book.status_zh || book.status_en) : (book.status_en || book.status_zh);
    }

    function bookIntroUrl(book) {
        return isChinese ? book.intro_url_zh : book.intro_url_en;
    }

    function summaryFor(post) {
        if (isChinese && post.summary_zh) return post.summary_zh;
        if (!isChinese && post.summary_en) return post.summary_en;
        if (post.summary) return post.summary;
        if (post.excerpt) return strip_html(post.excerpt).substring(0, 120);
        return strip_html(post.content).substring(0, 120);
    }
%>

<main class="content site-page-main">
    <section class="container hero-narrow">
        <p class="eyebrow"><%= isChinese ? '写作档案' : 'Writing library' %></p>
        <h1 class="page-title"><%= isChinese ? '技术长文、工作笔记与图示，按稳定主题长期整理。' : 'Essays, notes, and diagrams from an engineer’s working archive.' %></h1>
        <p class="lead"><%= isChinese ? '可搜索、有图片预览、按主题组织的技术写作档案。' : 'A searchable technical writing archive with visual previews and recurring systems topics.' %></p>
    </section>

    <section class="section compact">
        <div class="container">
            <% if (books.length) { %>
                <div class="section-head">
                    <h2><%= isChinese ? '长篇作品' : 'Long-form work' %></h2>
                    <p><%= isChinese ? '完整书稿放在独立站点，导读和相关短文继续进入写作档案。' : 'Complete books live on their own sites, while intros and related notes stay inside the writing archive.' %></p>
                </div>
                <div class="longform-list">
                    <% books.forEach(function(book) { %>
                        <article class="longform-card">
                            <div class="longform-mark">
                                <span><%= bookStatus(book) %></span>
                            </div>
                            <div class="summary-stack">
                                <span class="meta"><%= clusterLabels[book.topic_cluster] || (isChinese ? '长篇作品' : 'Long-form work') %></span>
                                <h3><a class="archive-row-link" href="<%- url_for(book.url) %>"><%= bookTitle(book) %></a></h3>
                                <p><%= bookSummary(book) %></p>
                            </div>
                            <div class="hero-actions longform-actions">
                                <a class="btn btn-primary" href="<%- url_for(book.url) %>"><%= isChinese ? '阅读完整书稿' : 'Read book' %></a>
                                <% if (bookIntroUrl(book)) { %>
                                    <a class="btn btn-secondary" href="<%- url_for(bookIntroUrl(book)) %>"><%= isChinese ? '导读' : 'Intro' %></a>
                                <% } %>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } %>

            <div class="filter-bar" aria-label="<%= isChinese ? '写作筛选' : 'Writing filters' %>">
                <div class="filter-group">
                    <% clusterButtons.forEach(function(button, index) { %>
                        <button class="filter-button <%= index === 0 ? 'is-active' : '' %>" type="button" data-filter="<%= button.key %>"><%= button.label %></button>
                    <% }); %>
                </div>
                <input class="search-field" type="search" data-search aria-label="<%= isChinese ? '搜索写作' : 'Search writing' %>" placeholder="<%= isChinese ? '搜索主题或标题' : 'Search writing topics' %>">
            </div>

            <div class="archive-list">
                <% allPosts.forEach(function(post) { %>
                    <% var previewAsset = post_preview_asset(post); %>
                    <article class="archive-row has-preview" data-topic="<%= post.topic_cluster || 'all' %>">
                        <% if (previewAsset) { %>
                            <a class="post-preview post-preview-image" href="<%- url_for(post.path) %>">
                                <img src="<%- url_for(previewAsset) %>" alt="<%= post.title %>">
                            </a>
                        <% } else { %>
                            <a class="post-preview preview-grid" href="<%- url_for(post.path) %>">
                                <span><%= clusterLabels[post.topic_cluster] || (isChinese ? '归档' : 'Archive') %></span>
                            </a>
                        <% } %>
                        <div class="summary-stack">
                            <span class="meta"><%= date(post.date, 'YYYY-MM-DD') %> · <%= clusterLabels[post.topic_cluster] || (isChinese ? '归档' : 'Archive') %></span>
                            <h3><a class="archive-row-link" href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
                            <p><%= summaryFor(post) %></p>
                        </div>
                        <span class="tag"><%= clusterLabels[post.topic_cluster] || (isChinese ? '归档' : 'Archive') %></span>
                    </article>
                <% }); %>
                <article class="archive-row has-preview" data-topic="enterprise-ai">
                    <div class="post-preview preview-grid"><span><%= isChinese ? '智能体 / 评估' : 'agent / eval' %></span></div>
                    <div class="summary-stack">
                        <span class="meta"><%= isChinese ? '公开主题' : 'Public theme' %> · <%= clusterLabels['enterprise-ai'] %></span>
                        <h3><%= isChinese ? '企业 AI 工作流与智能体评估' : 'Enterprise AI agents and workflow evaluation' %></h3>
                        <p><%= isChinese ? '这一主题暂时保留为公开写作方向：智能体工作流、评估、升级路径、治理与人工复核。' : 'This public track is reserved for future notes on agent workflows, evaluation, escalation, governance, and human review.' %></p>
                    </div>
                    <span class="tag"><%= clusterLabels['enterprise-ai'] %></span>
                </article>
            </div>

            <div class="archive-utilities">
                <div class="footer-links">
                    <a href="<%- url_for(isChinese ? '/archives-zh/' : '/archives/') %>"><%= isChinese ? '全部归档' : 'Full archives' %></a>
                    <a href="<%- url_for('/categories/') %>"><%= isChinese ? '分类' : 'Categories' %></a>
                    <a href="<%- url_for('/tags/') %>"><%= isChinese ? '标签' : 'Tags' %></a>
                </div>
            </div>
        </div>
    </section>
</main>
