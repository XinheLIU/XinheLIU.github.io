<%
    // Previous / next post navigation — quiet text cards, no stock-photo thumbnails.
    var isChinese = (page.site_locale || '').indexOf('zh') === 0;
    var languagePosts = [];
    site.posts.each(function (p) {
        if (p.hide !== true) {
            var pIsChinese = (p.site_locale || 'zh-CN').indexOf('zh') === 0;
            if (pIsChinese === isChinese) languagePosts.push(p);
        }
    });
    languagePosts.sort(function (a, b) { return new Date(b.date) - new Date(a.date); });
    var idx = languagePosts.findIndex(function (p) { return p.path === page.path; });
    var prevPost = (idx !== -1 && idx + 1 < languagePosts.length) ? languagePosts[idx + 1] : null;
    var nextPost = (idx > 0) ? languagePosts[idx - 1] : null;
    var prevLabel = isChinese ? '上一篇' : 'Previous';
    var nextLabel = isChinese ? '下一篇' : 'Next';
%>
<% if (prevPost || nextPost) { %>
<nav class="post-nav" aria-label="<%= isChinese ? '文章导航' : 'Post navigation' %>">
    <% if (prevPost) { %>
    <a class="post-nav-card" href="<%- url_for(prevPost.path) %>" rel="prev">
        <span class="post-nav-label">&larr;&nbsp;<%= prevLabel %></span>
        <span class="post-nav-title"><%= prevPost.title %></span>
    </a>
    <% } else { %><span></span><% } %>
    <% if (nextPost) { %>
    <a class="post-nav-card post-nav-card-next" href="<%- url_for(nextPost.path) %>" rel="next">
        <span class="post-nav-label"><%= nextLabel %>&nbsp;&rarr;</span>
        <span class="post-nav-title"><%= nextPost.title %></span>
    </a>
    <% } else { %><span></span><% } %>
</nav>
<% } %>
