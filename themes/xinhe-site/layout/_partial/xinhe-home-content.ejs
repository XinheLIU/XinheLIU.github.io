<%
    var allPosts = [];
    site.posts.each(function(post) {
        if (post.hide !== true) {
            var postIsChinese = (post.site_locale || 'zh-CN').indexOf('zh') === 0;
            if (postIsChinese === isChinese) {
                allPosts.push(post);
            }
        }
    });
    allPosts.sort(function(a, b) {
        return new Date(b.date) - new Date(a.date);
    });

    var books = site.data && site.data.books ? site.data.books : [];
    var clusterOrder = ['ads-systems', 'recommendation', 'experimentation', 'causal-measurement'];
    var clusterLabels = isChinese
        ? {
            'ads-systems': '广告系统',
            'recommendation': '推荐系统',
            'experimentation': '实验',
            'causal-measurement': '因果测量',
            'enterprise-ai': '企业 AI',
            'agentic-engineering': '智能体工程'
        }
        : {
            'ads-systems': 'Ads systems',
            'recommendation': 'Recommendation',
            'experimentation': 'Experimentation',
            'causal-measurement': 'Causal measurement',
            'enterprise-ai': 'Enterprise AI',
            'agentic-engineering': 'Agentic engineering'
        };

    var featuredPosts = clusterOrder.map(function(cluster) {
        return allPosts.find(function(post) {
            return post.topic_cluster === cluster;
        });
    }).filter(Boolean);

    var notesCount = allPosts.filter(function(post) {
        return !!post.note_type;
    }).length;

    var codingActivityFacts = isChinese
        ? [
            {
                label: 'Languages',
                value: 'Python / Markdown / JavaScript',
                detail: '最近 30 天的语言分布保留在 GitHub 主页，避免长期时间线淹没当前状态。'
            },
            {
                label: 'Editor time',
                value: 'Last 30 days',
                detail: 'WakaTime 每天刷新，用短窗口展示近期工作节奏。'
            },
            {
                label: 'Build/log/review work',
                value: 'Source + docs + automation',
                detail: '把编码、技术写作、自动化和复盘痕迹放在同一个公开入口。'
            }
        ]
        : [
            { label: 'Languages', value: 'Python / Markdown / JavaScript', detail: 'The GitHub profile keeps the last 30 days visible without the decade-long timeline.' },
            { label: 'Editor time', value: 'Last 30 days', detail: 'WakaTime refreshes daily so the signal stays current instead of historical.' },
            { label: 'Build/log/review work', value: 'Source + docs + automation', detail: 'Coding, technical writing, automation, and review traces share one public entry point.' }
        ];

    function bookTitle(book) {
        return isChinese ? (book.title_zh || book.title_en) : (book.title_en || book.title_zh);
    }

    function bookSummary(book) {
        return isChinese ? (book.summary_zh || book.summary_en) : (book.summary_en || book.summary_zh);
    }

    function bookStatus(book) {
        return isChinese ? (book.status_zh || book.status_en) : (book.status_en || book.status_zh);
    }

    function bookIntroUrl(book) {
        return isChinese ? book.intro_url_zh : book.intro_url_en;
    }

    function summaryFor(post) {
        if (isChinese && post.summary_zh) return post.summary_zh;
        if (!isChinese && post.summary_en) return post.summary_en;
        if (post.summary) return post.summary;
        if (post.excerpt) return strip_html(post.excerpt).substring(0, 120);
        return strip_html(post.content).substring(0, 120);
    }
%>

<main class="content site-page-main">
    <%- partial('_partial/profile-hero', { isChinese: isChinese }) %>

    <section class="section section-tinted">
        <div class="container">
            <div class="section-head">
                <h2><%= isChinese ? '写作与长篇作品' : 'Writing & Books' %></h2>
                <p><%= isChinese ? '完整书稿、导读和近期文章放在同一个入口，方便从首页进入对应阅读路径。' : 'Complete books, intros, and recent essays share one entry point from the home page.' %></p>
            </div>
            <div class="archive-list">
                <% books.forEach(function(book) { %>
                    <article class="archive-row has-preview">
                        <a class="post-preview preview-grid" href="<%- url_for(book.url) %>">
                            <span><%= bookStatus(book) %></span>
                        </a>
                        <div class="summary-stack">
                            <span class="meta"><%= bookStatus(book) %> · <%= clusterLabels[book.topic_cluster] || (isChinese ? '长篇作品' : 'Long-form work') %></span>
                            <h3><a class="archive-row-link" href="<%- url_for(book.url) %>"><%= bookTitle(book) %></a></h3>
                            <p><%= bookSummary(book) %></p>
                            <div class="hero-actions longform-actions">
                                <a class="btn btn-primary" href="<%- url_for(book.url) %>"><%= isChinese ? '阅读完整书稿' : 'Read book' %></a>
                                <% if (bookIntroUrl(book)) { %>
                                    <a class="btn btn-secondary" href="<%- url_for(bookIntroUrl(book)) %>"><%= isChinese ? '导读' : 'Intro' %></a>
                                <% } %>
                            </div>
                        </div>
                        <span class="tag"><%= clusterLabels[book.topic_cluster] || (isChinese ? '长篇作品' : 'Long-form work') %></span>
                    </article>
                <% }); %>
                <% featuredPosts.forEach(function(post) { %>
                    <% var previewAsset = post_preview_asset(post); %>
                    <article class="archive-row has-preview">
                        <% if (previewAsset) { %>
                            <a class="post-preview post-preview-image" href="<%- url_for(post.path) %>">
                                <img src="<%- url_for(previewAsset) %>" alt="<%= post.title %>">
                            </a>
                        <% } else { %>
                            <a class="post-preview preview-grid" href="<%- url_for(post.path) %>">
                                <span><%= clusterLabels[post.topic_cluster] %></span>
                            </a>
                        <% } %>
                        <div class="summary-stack">
                            <span class="meta"><%= date(post.date, 'YYYY-MM-DD') %> · <%= clusterLabels[post.topic_cluster] %></span>
                            <h3><a class="archive-row-link" href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
                            <p><%= summaryFor(post) %></p>
                        </div>
                        <span class="tag"><%= clusterLabels[post.topic_cluster] %></span>
                    </article>
                <% }); %>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <div class="section-head">
                <h2><%= isChinese ? '项目线索' : 'Project threads' %></h2>
                <p><%= isChinese ? '围绕问题类型、系统边界和技术判断整理可公开分享的项目方向。' : 'Public project notes organized around problem types, system boundaries, and technical judgment.' %></p>
            </div>
            <div class="card-grid two">
                <article class="card">
                    <h3><%= isChinese ? '增长与测量系统' : 'Growth and measurement systems' %></h3>
                    <p><%= isChinese ? '把模糊增长目标翻译成指标、实验、上线标准和反馈闭环。' : 'Translating ambiguous growth goals into metrics, experiments, launch criteria, and operating feedback.' %></p>
                </article>
                <article class="card">
                    <h3><%= isChinese ? '推荐与广告基础设施' : 'Recommendation and ads infrastructure' %></h3>
                    <p><%= isChinese ? '围绕排序、召回、分配和测量，平衡用户价值、市场约束与业务目标。' : 'Ranking, retrieval, allocation, and measurement layers that balance user value, marketplace constraints, and business goals.' %></p>
                </article>
                <article class="card">
                    <h3><%= isChinese ? '因果测量与实验' : 'Causal measurement and experimentation' %></h3>
                    <p><%= isChinese ? '关注 lift、holdout、归因窗口和反事实推断。' : 'Separating lift from correlation with holdouts, attribution windows, and counterfactual reasoning.' %></p>
                </article>
                <article class="card">
                    <h3><%= isChinese ? '企业 AI 与智能体工作流' : 'Enterprise AI and agent workflows' %></h3>
                    <p><%= isChinese ? '把评估、升级路径、人类复核和治理合同放在自动化之前。' : 'Putting evaluation, escalation, human review, and governance contracts ahead of workflow automation.' %></p>
                </article>
            </div>

            <aside class="coding-activity-panel" aria-labelledby="coding-activity-title">
                <div class="coding-activity-copy">
                    <span class="coding-activity-kicker"><%= isChinese ? 'Last 30 days' : 'Last 30 days' %></span>
                    <h3 id="coding-activity-title"><%= isChinese ? '编码活动' : 'Coding activity' %></h3>
                    <p><%= isChinese ? '保留 WakaTime 作为近期工作信号，但只展示短窗口和高层结构，避免旧的长时间线抢走首页注意力。' : 'WakaTime stays as a current work signal, but the public surface stays short, structured, and separate from the old long-range chart.' %></p>
                    <div class="hero-actions coding-activity-actions">
                        <a class="btn btn-secondary" href="https://github.com/XinheLIU" target="_blank" rel="noopener">
                            <%= isChinese ? '查看 GitHub 活动' : 'View GitHub activity' %>
                        </a>
                    </div>
                </div>
                <div class="coding-activity-facts">
                    <% codingActivityFacts.forEach(function(fact) { %>
                        <div class="coding-activity-fact">
                            <span><%= fact.label %></span>
                            <strong><%= fact.value %></strong>
                            <p><%= fact.detail %></p>
                        </div>
                    <% }); %>
                </div>
            </aside>
        </div>
    </section>

    <section class="section section-tinted">
        <div class="container split-panel">
            <aside class="sidebar-panel">
                <h2><%= isChinese ? '继续阅读' : 'Continue through the site' %></h2>
                <p><%= isChinese ? '从这里继续进入写作、技术笔记、项目线索和个人信息。' : 'Continue into writing, technical notes, project threads, and contact details.' %></p>
                <div class="summary-list">
                    <div class="summary-item">
                        <strong><%= isChinese ? '写作' : 'Writing' %></strong>
                        <span><%= isChinese ? '长文、主题簇、摘要和阅读路径。' : 'Long-form essays, topic clusters, summaries, and reading paths.' %></span>
                    </div>
                    <div class="summary-item">
                        <strong><%= isChinese ? '技术笔记' : 'Technical Notes' %></strong>
                        <span><%= isChinese ? '图示、约束、方法和更密集的实现痕迹。' : 'Diagrams, invariants, methods, and denser implementation traces.' %></span>
                    </div>
                    <div class="summary-item">
                        <strong><%= isChinese ? '个人信息和联系方式' : 'About & Contact' %></strong>
                        <span><%= isChinese ? '集中展示专业叙事、GitHub、邮箱和交流主题。' : 'A compact professional narrative, GitHub, email, and focused collaboration prompts.' %></span>
                    </div>
                </div>
            </aside>
            <div class="quiet-callout">
                <h3><%= isChinese ? '个人信息和联系方式' : 'About and contact' %></h3>
                <p><%= isChinese ? '关于我的专业方向、公开写作边界、GitHub 和邮件入口。' : 'Professional background, publication boundaries, GitHub, and email in one place.' %></p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="<%- url_for(isChinese ? '/about-zh/' : '/about/') %>"><%= isChinese ? '查看个人信息和联系方式' : 'Open About & Contact' %></a>
                    <a class="btn btn-secondary" href="<%- url_for(isChinese ? '/projects-zh/' : '/projects/') %>"><%= isChinese ? '查看项目线索' : 'View project threads' %></a>
                </div>
                <div class="archive-utilities">
                    <div class="footer-links">
                        <a href="<%- url_for(isChinese ? '/archives-zh/' : '/archives/') %>"><%= isChinese ? '归档' : 'Archives' %></a>
                        <a href="<%- url_for('/categories/') %>"><%= isChinese ? '分类' : 'Categories' %></a>
                        <a href="<%- url_for('/tags/') %>"><%= isChinese ? '标签' : 'Tags' %></a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
