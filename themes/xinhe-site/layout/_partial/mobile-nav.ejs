<%
    var isChinese = (page.site_locale || '').indexOf('zh') === 0;
    var navItems = isChinese
        ? [
            { label: '首页', path: '/home-zh/' },
            { label: '写作', path: '/writing-zh/' },
            { label: '技术笔记', path: '/technical-notes-zh/' },
            { label: '项目', path: '/projects-zh/' },
            { label: '个人信息和联系方式', path: '/about-zh/' }
        ]
        : [
            { label: 'Home', path: '/' },
            { label: 'Writing', path: '/writing/' },
            { label: 'Technical Notes', path: '/technical-notes/' },
            { label: 'Projects', path: '/projects/' },
            { label: 'About & Contact', path: '/about/' }
        ];
    var langSwitchHref = page.lang_switch || (isChinese ? '/' : '/home-zh/');
%>
<div id="mobile-nav" class="sidenav site-mobile-nav">
    <div class="mobile-nav-head">
        <a class="brand-lockup" href="<%- url_for(isChinese ? '/home-zh/' : '/') %>">
            <span class="brand-mark">X</span>
            <span class="brand-name">
                <strong><%= isChinese ? '昕和' : 'Charles' %></strong>
                <span><%= isChinese ? '个人网站' : 'Personal site' %></span>
            </span>
        </a>
        <p><%= isChinese ? '昕和的个人主页、写作与技术笔记。' : 'Charles: personal site, writing, and technical notes.' %></p>
    </div>

    <ul class="mobile-nav-list">
        <% navItems.forEach(function(item) { %>
            <li><a href="<%- url_for(item.path) %>"><%= item.label %></a></li>
        <% }); %>
    </ul>

    <div class="mobile-nav-actions">
        <a href="#searchModal" class="modal-trigger nav-utility sidenav-close" aria-label="<%= isChinese ? '搜索' : 'Search' %>">
            <i class="fas fa-search"></i>
        </a>
        <a class="lang-switch" href="<%- url_for(langSwitchHref) %>"><%= isChinese ? 'EN' : '中' %></a>
        <button class="theme-toggle" type="button" data-theme-toggle>●</button>
    </div>

    <div class="mobile-secondary-links">
        <a href="<%- url_for('/tags/') %>"><%= isChinese ? '标签' : 'Tags' %></a>
        <a href="<%- url_for('/categories/') %>"><%= isChinese ? '分类' : 'Categories' %></a>
        <a href="<%- url_for('/archives/') %>"><%= isChinese ? '归档' : 'Archives' %></a>
    </div>
</div>
