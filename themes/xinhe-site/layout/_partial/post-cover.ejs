<%
    // Quiet typographic post header (replaces the old full-bleed photo banner).
    var isChinese = (page.site_locale || '').indexOf('zh') === 0;
    var categoryName = '';
    if (page.categories && page.categories.length) {
        page.categories.forEach(function (c) { if (!categoryName) categoryName = c.name; });
    }
    var readMins = (typeof min2read === 'function') ? min2read(page.content) : null;
%>
<header class="post-hero content">
    <div class="container">
        <% if (categoryName) { %>
            <p class="eyebrow"><%= categoryName %></p>
        <% } %>
        <h1 class="page-title"><%= page.title %></h1>
        <div class="post-meta">
            <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>"><%= date(page.date, 'YYYY-MM-DD') %></time>
            <% if (readMins) { %>
                <span class="dot">·</span>
                <span><%= readMins %> <%= isChinese ? '分钟' : 'min read' %></span>
            <% } %>
            <% if (page.tags && page.tags.length) { %>
                <span class="post-hero-tags">
                    <% page.tags.forEach(function (tag) { %>
                        <a class="chip" href="<%- url_for(tag.path) %>"><%= tag.name %></a>
                    <% }); %>
                </span>
            <% } %>
        </div>
        <hr class="post-hero-rule">
    </div>
</header>
